# PQT Website environment

# Public site base URL (set in production so share links/OG images are correct)
NEXT_PUBLIC_SITE_URL="http://localhost:3003"

# --- Demo portal auth (until PMS NextAuth integration) ---
# Secret used to HMAC-sign the demo session cookie. REQUIRED in production.
# SESSION_SECRET="generate-a-long-random-string"
# Only this email receives the internal agent view at login. Unset = nobody.
# DEMO_AGENT_EMAIL="agent@your-private-address"

# --- Lead delivery (contact + enquiry + reservation forms) ---
# Without these, production forms show an honest "email us directly" fallback.
# RESEND_API_KEY=""
# LEADS_TO_EMAIL="sales@propertyquestturkey.com"
# Optional custom sender (defaults to Resend's onboarding sender):
# LEADS_FROM_EMAIL="PQT Website <noreply@propertyquestturkey.com>"

# --- Future PMS integration ---
# Shared Postgres DB (same database the PMS uses — read-only for public listings).
# DATABASE_URL="postgresql://user:pass@host:5432/pqt"
